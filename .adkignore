# Files NOT uploaded to Vertex AI when `adk deploy agent_engine` runs.
# Same syntax as .gitignore.

# Python virtual environments
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Secrets and local config — never ship to the cloud
.env
.env.*
credentials/
*-sa-key.json
*-key.json
*service-account*.json
*credentials*.json
!requirements.txt

# Git
.git
.git/
.git/**
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.claude/

# OS
.DS_Store
Thumbs.db

# Other ignore files
.gcloudignore

# Terraform (never goes to the Reasoning Engine container)
terraform/
.terraform/
**/.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Operator scripts (not needed at runtime)
deploy_and_update.sh
register_agent.py

# Docs (don't bloat the container)
README.md
AGENTS.md
NOTICE
THIRD_PARTY_LICENSES
.github/
